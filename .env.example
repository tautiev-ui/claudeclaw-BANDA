# ClaudeClaw BANDA overlay env example
# Copy to the cloned ClaudeClaw runtime as .env, then fill real values locally.
# Never commit real tokens.

# Main coordinator bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID
ALLOWED_CHAT_ID=

# BANDA sub-agent bot tokens from @BotFather
TUCO_BOT_TOKEN=
LALO_BOT_TOKEN=
GALE_BOT_TOKEN=
KIM_BOT_TOKEN=

# Optional: Claude Code normally uses `claude login`.
# Set this only if your upstream ClaudeClaw runtime supports API-key mode.
ANTHROPIC_API_KEY=

# Optional: embeddings / speech / integrations depend on upstream ClaudeClaw support.
OPENAI_API_KEY=
GROQ_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
GOOGLE_API_KEY=
