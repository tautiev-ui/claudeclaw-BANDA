DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=<set-in-secret-manager>
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=<domain>,www.<domain>
DATABASE_URL=postgres://<user>:<password>@<host>:5432/<database>
REDIS_URL=redis://127.0.0.1:6379/0
MEILISEARCH_URL=http://127.0.0.1:7700
MEILISEARCH_MASTER_KEY=<set-in-secret-manager>
YANDEX_VERIFICATION=<optional-verification-meta>
GOOGLE_SITE_VERIFICATION=<optional-verification-meta>
S3_ENDPOINT_URL=<optional-object-storage-endpoint>
S3_ACCESS_KEY_ID=<optional-access-key-id>
S3_SECRET_ACCESS_KEY=<optional-secret-access-key>
